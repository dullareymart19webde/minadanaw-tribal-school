rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Function to get current user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Users Collection
    match /users/{userId} {
      // Anyone can create their initial user document (registration)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can read their own profile, admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Only admins can update or delete users (prevents status tampering)
      allow update, delete: if isAdmin();
    }

    // Students Collection
    match /students/{studentDocId} {
      // Students can create their profile on registration
      allow create: if isAuthenticated();
      // Students can read their own profile (matching by email or id), admins can read all
      allow read: if isAuthenticated() && (isAdmin() || (getUserData().role == 'student'));
      // Only admins can update (approve applications) or delete
      allow update, delete: if isAdmin();
    }
    
    // Master List (Courses, subjects, etc.)
    match /masterlist/{docId} {
      // Anyone authenticated can read
      allow read: if isAuthenticated();
      // Only admins can modify
      allow write: if isAdmin();
    }
    
    // Events & News
    match /news/{docId} {
      allow read: true;
      allow write: if isAdmin();
    }
    
    match /events/{docId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // Default rule: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
